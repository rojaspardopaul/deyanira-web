# ─ apps/api/.env.example ─
# Subset usado en el backend.  Para la lista completa ver el .env.example raíz.

NODE_ENV=development
PORT=3001

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres:<password>@db.xxxxx.supabase.co:5432/postgres
DIRECT_URL=

ADMIN_JWT_SECRET=
ADMIN_JWT_LIFETIME=8h

# Cookies cross-subdomain
# COOKIE_DOMAIN=.deyanira.pe

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

BCRYPT_COST=12

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CULQI_PUBLIC_KEY=pk_test_
CULQI_SECRET_KEY=sk_test_

RESEND_API_KEY=re_
EMAIL_FROM=admin@deyaniramakeup.pe
SALON_ADMIN_EMAIL=admin@deyanira.pe

WHATSAPP_NUMBER=+51XXXXXXXXX
SALON_WHATSAPP=+51XXXXXXXXX
YAPE_NUMBER=+51XXXXXXXXX

# Cloudflare Turnstile (anti-bot). Opcional: sin la llave la verificación es no-op.
TURNSTILE_SECRET_KEY=

# Secreto compartido con el frontend para purgar su caché Next on-demand tras
# mutaciones admin (debe ser idéntico a REVALIDATE_SECRET del frontend). Opcional.
REVALIDATE_SECRET=

# ── Feature flags de migración (Strangler Fig) ────────────────
# Con 'true', el módulo appointments intercepta la GESTIÓN ADMIN de citas
# (GET/POST /admin/appointments, /confirm-group, PATCH /admin/appointments/:id).
# El alta de paquetes con adelanto (POST /admin/appointments/package) sigue en el
# legacy. Rollback instantáneo = poner 'false' (o quitarlo) y reiniciar la API.
CITAS_ADMIN_MODULO_NUEVO=false
