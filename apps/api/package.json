{
  "name": "@deyanira/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "build": "prisma generate",
    "start": "tsx src/index.js",
    "dev": "tsx watch src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "eslint src/",
    "backfill:finanzas": "tsx scripts/backfill-financial-movements.js"
  },
  "dependencies": {
    "@deyanira/contracts": "*",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.1",
    "otplib": "^13.4.1",
    "prisma": "^7.8.0",
    "puppeteer": "^25.2.1",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "slugify": "^1.6.6",
    "tsx": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.7.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
