{
  "name": "@deyanira/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "build": "prisma generate",
    "start": "tsx src/index.js",
    "dev": "tsx watch src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "eslint src/",
    "backfill:finanzas": "tsx scripts/backfill-financial-movements.js"
  },
  "dependencies": {
    "@deyanira/contracts": "*",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.46.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^10.4.3",
    "otplib": "^12.0.1",
    "prisma": "^5.22.0",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0",
    "slugify": "^1.6.6",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.7.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
