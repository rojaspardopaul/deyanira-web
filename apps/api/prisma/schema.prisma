// ─── CENTRO FINANCIERO (ledger central) ───────────────────
// Cuenta/caja financiera. Todo movimiento puede pertenecer a una cuenta
// (Caja Principal, Yape, Banco). Single-tenant: sin tenantId/branchId.
model FinancialAccount {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  type      String              @default("cash")
  // cash | wallet | bank | card
  isActive  Boolean             @default(true) @map("is_active")
  sortOrder Int                 @default(0) @map("sort_order")
  createdAt DateTime            @default(now()) @map("created_at")
  movements FinancialMovement[]

  @@map("financial_accounts")
}

// Libro mayor único (append-first). Cada fuente de dinero (cita completada,
// adelanto pagado, pedido pagado, egreso, otro ingreso, ajuste manual) crea una
// fila con `source` + el id de la entidad origen para trazabilidad. La captura
// manual (Expense/OtherIncome) sigue existiendo y además proyecta un movimiento.
model FinancialMovement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  direction     String
  // in | out
  type          String
  // ingreso | egreso | adelanto | pago_final | venta | reembolso | ajuste | transferencia | comision | impuesto
  status        String   @default("settled")
  // settled | pending | void
  amountPen     Decimal  @map("amount_pen") @db.Decimal(10, 2)
  category      String?
  description   String
  occurredAt    DateTime @map("occurred_at") @db.Date
  paymentMethod String?  @map("payment_method")
  // efectivo | transferencia | tarjeta | yape | plin | culqi

  // Origen / trazabilidad (todos nullable; suele estar set solo uno)
  source           String
  // appointment | booking_payment | order | expense | other_income | manual
  appointmentId    String? @map("appointment_id") @db.Uuid
  bookingPaymentId String? @map("booking_payment_id") @db.Uuid
  orderId          String? @map("order_id") @db.Uuid
  expenseId        String? @map("expense_id") @db.Uuid
  otherIncomeId    String? @map("other_income_id") @db.Uuid
  customerId       String? @map("customer_id") @db.Uuid
  staffId          String? @map("staff_id") @db.Uuid

  accountId String?           @map("account_id") @db.Uuid
  account   FinancialAccount? @relation(fields: [accountId], references: [id])

  receiptUrl String?   @map("receipt_url")
  createdBy  String?   @map("created_by")
  voidedAt   DateTime? @map("voided_at")
  voidReason String?   @map("void_reason")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([occurredAt])
  @@index([direction, occurredAt])
  @@index([source])
  @@index([type])
  @@index([appointmentId])
  @@index([bookingPaymentId])
  @@index([orderId])
  @@map("financial_movements")

  vouchers FinancialVoucher[]
}

// Comprobante (voucher) adjunto a un movimiento: imagen o PDF en Cloudinary.
// Un movimiento puede tener varios (boleta + captura de Yape, etc.).
model FinancialVoucher {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  movementId String   @map("movement_id") @db.Uuid
  movement   FinancialMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  url        String
  fileType   String   @default("image") @map("file_type") // image | pdf
  fileName   String?  @map("file_name")
  publicId   String?  @map("public_id") // para borrar en Cloudinary
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([movementId])
  @@map("financial_vouchers")
}
