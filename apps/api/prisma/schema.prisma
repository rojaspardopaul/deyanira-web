// ─── CONFIGURACIÓN DEL SALÓN ──────────────────────────────

model Setting {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salonName           String   @default("Deyanira Makeup Beauty") @map("salon_name")
  phone               String?
  whatsapp            String?
  email               String?
  address             String?
  district            String?
  city                String   @default("Lima")
  lat                 Decimal  @default(-12.1109913) @db.Decimal(10, 7)
  lng                 Decimal  @default(-76.8182017) @db.Decimal(10, 7)
  // Hora mínima de inicio para reservar. Default 09:00, pero los paquetes pueden requerir antes.
  bookingMinHour      String   @default("09:00") @map("booking_min_hour")
  // Hora mínima específica para paquetes (eventos novia/quinceañera). Si null, usa bookingMinHour.
  packageMinHour      String?  @map("package_min_hour")
  hoursWeekday        String   @default("9:00 - 19:00") @map("hours_weekday")
  hoursSaturday       String   @default("9:00 - 17:00") @map("hours_saturday")
  hoursSunday         String   @default("Cerrado") @map("hours_sunday")
  facebookUrl         String?  @map("facebook_url")
  instagramUrl        String?  @map("instagram_url")
  tiktokUrl           String?  @map("tiktok_url")
  bookingNoticeHours  Int      @default(2) @map("booking_notice_hours")
  cancellationHours   Int      @default(24) @map("cancellation_hours")
  // Servicio a domicilio
  atHomeEnabled       Boolean  @default(false) @map("at_home_enabled")
  storeEnabled        Boolean  @default(true) @map("store_enabled") // tienda online visible
  atHomeBasePen       Decimal  @default(120.00) @map("at_home_base_pen") @db.Decimal(10, 2)
  atHomeBaseKm        Int      @default(15) @map("at_home_base_km")
  atHomeRatePen       Decimal  @default(4.00) @map("at_home_rate_pen") @db.Decimal(10, 2)
  // Distritos donde se ofrece "yo recojo a la estilista" (sin recargo). Default: sede.
  pickupDistricts     String[] @default(["Cieneguilla"]) @map("pickup_districts")
  // Timer de reserva (segundos que tiene el cliente para confirmar en el paso final)
  bookingTimerSeconds Int      @default(600) @map("booking_timer_seconds")
  // Horas que se mantiene una reserva de paquete con adelanto pendiente antes de
  // liberarse automáticamente (cancela las citas y suelta el horario).
  depositExpiryHours  Int      @default(24) @map("deposit_expiry_hours")
  // Datos de pago mostrados al cliente para abonar por transferencia/Yape/Plin
  yapeNumber          String?  @map("yape_number")
  yapeName            String?  @map("yape_name")
  plinNumber          String?  @map("plin_number")
  bankName            String?  @map("bank_name")
  bankAccount         String?  @map("bank_account")
  bankCci             String?  @map("bank_cci")
  bankAccountHolder   String?  @map("bank_account_holder")
  // Identidad visual — logos subidos desde el admin
  logoUrl             String?  @map("logo_url") // Logo para fondos claros (versión oscura)
  logoDarkUrl         String?  @map("logo_dark_url") // Logo para fondos oscuros (versión blanca)
  logoIconUrl         String?  @map("logo_icon_url") // Ícono cuadrado (favicon / cabecera pequeña)
  teamPhotoUrl        String?  @map("team_photo_url") // Foto grupal del equipo (página Nosotros)
  salonPhotoUrl       String?  @map("salon_photo_url") // Foto del salón (fondo del hero en Nosotros)
  // Slides del carrusel del home: array de { imageUrl?, videoUrl?, badge, line1, line2, bullets[], ctaText, ctaHref, gravity }
  homeSlides          Json     @default("[]") @map("home_slides")
  // Identificación legal del proveedor (Libro de Reclamaciones / INDECOPI)
  razonSocial         String?  @map("razon_social")
  ruc                 String?  @map("ruc")
  // Páginas legales (markdown, editables desde el admin)
  termsMd             String?  @map("terms_md")
  returnsPolicyMd     String?  @map("returns_policy_md")
  privacyMd           String?  @map("privacy_md")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

// ─── LIBRO DE RECLAMACIONES (INDECOPI) ────────────────────
// Hoja de reclamación digital integrada (no depende de formularios externos).

enum TipoReclamoBien {
  PRODUCTO
  SERVICIO
}

enum TipoReclamo {
  RECLAMO // Disconformidad con el producto/servicio
  QUEJA   // Malestar respecto a la atención
}

enum EstadoReclamo {
  PENDIENTE
  RESPONDIDO
  CERRADO
}

model HojaReclamacion {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  correlativo     String           @unique // p.ej. LR-2026-000123
  // Consumidor
  consumidorNombre   String        @map("consumidor_nombre")
  consumidorTipoDoc  String        @map("consumidor_tipo_doc") // DNI / CE / Pasaporte / RUC
  consumidorNumDoc   String        @map("consumidor_num_doc")
  consumidorDomicilio String       @map("consumidor_domicilio")
  consumidorTelefono String?       @map("consumidor_telefono")
  consumidorEmail    String        @map("consumidor_email")
  esMenor            Boolean       @default(false) @map("es_menor")
  apoderadoNombre    String?       @map("apoderado_nombre")
  // Bien contratado
  bienTipo        TipoReclamoBien  @map("bien_tipo")
  montoReclamado  Decimal?         @map("monto_reclamado") @db.Decimal(10, 2)
  bienDescripcion String           @map("bien_descripcion")
  // Detalle del reclamo/queja
  tipo            TipoReclamo
  detalle         String
  pedido          String
  // Gestión interna
  estado          EstadoReclamo    @default(PENDIENTE)
  respuesta       String?
  respondidoAt    DateTime?        @map("respondido_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([estado, createdAt])
  @@map("hojas_reclamacion")
}

// ─── ADMINISTRADORES ──────────────────────────────────────

model Admin {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String  @unique
  passwordHash String  @map("password_hash")
  role         String  @default("admin") // super_admin | admin | estilista
  staffId      String? @map("staff_id") @db.Uuid
  staff        Staff?  @relation(fields: [staffId], references: [id])
  isActive     Boolean @default(true) @map("is_active")

  // ── MFA (TOTP) ────────────────────────────────
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  mfaSecret      String?  @map("mfa_secret") // cifrado en reposo (lib/crypto)
  mfaBackupCodes String[] @default([]) @map("mfa_backup_codes") // hashes de códigos de respaldo

  // Invalida tokens emitidos antes de este timestamp
  // (subir al cambiar password, rol, isActive=false, etc.)
  tokensValidFrom DateTime @default(now()) @map("tokens_valid_from")

  passwordChangedAt DateTime? @map("password_changed_at")
  lastLoginAt       DateTime? @map("last_login_at")
  lastLoginIp       String?   @map("last_login_ip")

  createdAt DateTime @default(now()) @map("created_at")

  auditLogs AuditLog[] @relation("AdminAuditActor")

  @@map("admins")
}

// ─── AUDIT LOG (acciones admin) ───────────────────────────
// Append-only. Nunca update/delete desde la app.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actor      Admin?   @relation("AdminAuditActor", fields: [actorId], references: [id])
  actorEmail String?  @map("actor_email")
  action     String // "admin.user.create", "admin.order.update", etc.
  entity     String? // "Admin" | "Order" | "Service" | "Settings" ...
  entityId   String?  @map("entity_id")
  method     String?
  path       String?
  ip         String?
  userAgent  String?  @map("user_agent")
  changes    Json? // diff before/after (sanitizado, sin password)
  statusCode Int?     @map("status_code")
  requestId  String?  @map("request_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── PASSWORD RESET (admin) ──────────────────────────────
model AdminPasswordReset {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId   String    @map("admin_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // sha256 del token (nunca guardamos plaintext)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_password_resets")
}

// ─── CULQI WEBHOOK EVENTS ────────────────────────────────
