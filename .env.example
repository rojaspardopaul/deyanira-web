# ============================================================
# DEYANIRA WEB — Variables de Entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# ----- SUPABASE (Base de datos + Auth) -----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # SECRETO — solo para el backend
DATABASE_URL=postgresql://postgres:<password>@db.xxxxx.supabase.co:5432/postgres

# ----- JWT ADMIN (panel de administración) -----
ADMIN_JWT_SECRET=<genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
ADMIN_JWT_LIFETIME=8h

# ----- CLOUDINARY (imágenes) -----
CLOUDINARY_CLOUD_NAME=deyanira-makeup
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- CULQI (pagos Perú) -----
CULQI_PUBLIC_KEY=pk_test_
CULQI_SECRET_KEY=sk_test_

# ----- RESEND (emails) -----
RESEND_API_KEY=re_
EMAIL_FROM=hola@deyanira.pe

# ----- WHATSAPP BUSINESS -----
WHATSAPP_NUMBER=+51XXXXXXXXX

# ----- CORS -----
FRONTEND_URL=http://localhost:3000

# ----- ENTORNO -----
NODE_ENV=development
PORT=3001

# ============================================================
# FRONTEND (Next.js) — variables públicas NEXT_PUBLIC_*
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...   # clave pública, segura en el cliente
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxxx
NEXT_PUBLIC_WHATSAPP_NUMBER=+51XXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
