# ============================================================
# DEYANIRA WEB — Variables de Entorno
#
# Copiar a .env y completar con valores reales.
# NUNCA commitear archivos .env*.local ni .env.production.
#
# Validación strict-fail-fast en arranque: ver apps/api/src/lib/env.js
# ============================================================

# ── ENTORNO ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── SUPABASE (DB + Auth de clientes) ────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # SECRETO — sólo backend
SUPABASE_JWT_SECRET=                   # Para verificación local de JWT sin red
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── JWT ADMIN ───────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# >= 32 chars (recomendado 64+). Rotar al menos cada 90 días.
ADMIN_JWT_SECRET=
ADMIN_JWT_LIFETIME=8h

# ── COOKIES ─────────────────────────────────────────────────
# Para que la cookie funcione cross-subdomain (api.* + www.*) en prod
# COOKIE_DOMAIN=.deyanira.pe

# ── CORS ────────────────────────────────────────────────────
# Lista separada por comas. NO incluyas http://localhost en producción.
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://deyanira.pe,https://www.deyanira.pe

# ── BCRYPT ──────────────────────────────────────────────────
# Cost factor: 10 dev, 12 prod (mínimo recomendado en 2026)
BCRYPT_COST=12

# ── CLOUDINARY ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=deyanira-makeup
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CULQI (pagos Perú) ──────────────────────────────────────
CULQI_PUBLIC_KEY=pk_test_
CULQI_SECRET_KEY=sk_test_

# Usuario de pruebas: por ahora el pago con tarjeta (Culqi) en checkout y
# reservas SOLO se habilita para este email. Debe coincidir con
# NEXT_PUBLIC_TEST_CUSTOMER_EMAIL (frontend). Default: test.customer@deyanira.pe
TEST_CUSTOMER_EMAIL=test.customer@deyanira.pe
TEST_CUSTOMER_PASSWORD=
TEST_CUSTOMER_NAME=Usuario Test

# ── RESEND (emails) ─────────────────────────────────────────
RESEND_API_KEY=re_
EMAIL_FROM=Deyanira Makeup Beauty <admin@deyaniramakeup.pe>
SALON_ADMIN_EMAIL=admin@deyanira.pe

# ── WHATSAPP BUSINESS ───────────────────────────────────────
WHATSAPP_NUMBER=+51XXXXXXXXX
SALON_WHATSAPP=+51XXXXXXXXX
YAPE_NUMBER=+51XXXXXXXXX

# ── CLOUDFLARE TURNSTILE (anti-bot, opcional) ───────────────
# Sin esta llave la verificación es no-op (no bloquea dev/local).
TURNSTILE_SECRET_KEY=

# ── REVALIDACIÓN ON-DEMAND (caché Next) ─────────────────────
# Secreto compartido api↔web para purgar la caché de datos de Next tras
# mutaciones admin. Debe ser el MISMO valor en api y web. Opcional.
REVALIDATE_SECRET=

# ============================================================
# FRONTEND (Next.js) — variables públicas NEXT_PUBLIC_*
# Estas viajan al navegador. NO poner secretos.
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...   # clave pública (anon), segura en cliente
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=https://deyanira.pe
NEXT_PUBLIC_WEB_URL=https://deyanira.pe
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_
# Debe coincidir con TEST_CUSTOMER_EMAIL (backend). Habilita el pago con tarjeta solo a este usuario.
NEXT_PUBLIC_TEST_CUSTOMER_EMAIL=test.customer@deyanira.pe
# Site key de Cloudflare Turnstile (público). Sin esta llave el widget no se muestra.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxxx
NEXT_PUBLIC_WHATSAPP_NUMBER=+51XXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================
# Build escape hatches (sólo emergencias — NO usar en prod estable)
# ============================================================
# SKIP_TS=true    # ignora errores de TypeScript en build
# SKIP_LINT=true  # ignora errores de ESLint en build
